
config aria2 'main'
	option enabled '1'
	option user 'root'
	option dir '/mnt/mmcblk2p4/download'
	option config_dir '/var/etc/aria2'
	option bt_enable_lpd 'true'
	option enable_dht 'true'
	option follow_torrent 'true'
	option file_allocation 'none'
	option save_session_interval '30'
	option enable_logging '0'
	option rpc_auth_method 'none'
	option rpc_secure 'false'
	option enable_proxy '0'
	option check_certificate 'false'
	option enable_dht6 'false'
	option enable_peer_exchange 'true'
	option connect_timeout '60'
	option timeout '60'
	option lowest_speed_limit '0'
	option max_connection_per_server '1'
	option split '5'
	option min_split_size '20M'
	option max_tries '10'
	option retry_wait '10'
	option rpc_listen_port '6800'
	option max_concurrent_downloads '10'

