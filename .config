# =========================================================
# ImmortalWrt 极简旁路由种子配置 (Seed Config)
# 架构: ARM64 (armvirt/64) - 用于 ophub 打包 S905X3
# =========================================================

# --- 核心目标平台 (二选一，根据实际版本选择) ---

# 【选项A】ImmortalWrt 24.10+ / OpenWrt 24.10+ 使用此组
CONFIG_TARGET_armsr=y
CONFIG_TARGET_armsr_armv8=y
# CONFIG_TARGET_armsr_armv7 is not set

# 【选项B】若仍使用旧版 armvirt 命名则改用此组（注释掉选项A）
# CONFIG_TARGET_armvirt=y
# CONFIG_TARGET_armvirt_64=y

# --- 强制禁用 x86 (防止误编译) ---
# CONFIG_TARGET_x86 is not set
# CONFIG_TARGET_x86_64 is not set
# CONFIG_TARGET_x86_generic is not set
# CONFIG_TARGET_x86_legacy is not set
# CONFIG_TARGET_x86_geode is not set

# --- 根文件系统输出格式 (ophub 打包必需) ---
CONFIG_TARGET_ROOTFS_TARGZ=y
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

# --- 基础架构确认 ---
CONFIG_ARCH_64BIT=y
CONFIG_aarch64=y
CONFIG_CPU_TYPE="cortex-a55"


# ⭐ 关键：防止 rootfs 空间不足导致编译失败
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# --- 2. 主题配置 (Theme) ---
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
# CONFIG_PACKAGE_luci-theme-bootstrap is not set

# --- 3. 第三方插件 (Amlogic & Socat) ---
CONFIG_PACKAGE_luci-app-amlogic=y
CONFIG_PACKAGE_luci-i18n-amlogic-zh-cn=y
CONFIG_PACKAGE_luci-app-socat=y
CONFIG_PACKAGE_luci-i18n-socat-zh-cn=y
CONFIG_PACKAGE_socat=y

# --- 4. 官方 Feeds 插件 (ZeroTier) ---
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y

# ================= 基础 UI =================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y

# ================= 系统与监控工具 =================
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y

# ================= 网络与共享服务 =================
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-firewall=y

# ================= 存储与下载工具 =================
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_luci-app-aria2=y
CONFIG_PACKAGE_aria2=y
CONFIG_PACKAGE_luci-app-commands=y

# ================= USB 与文件系统支持 =================
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_block-mount=y

# ================= 基础网络组件 =================
CONFIG_IPV6=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

# --- 5. 无线网络支持 (仅保留通用框架) ---
# ⚠️ 已移除 6.18.y 不兼容的 Realtek 非主线驱动
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_wireless-tools=y
CONFIG_PACKAGE_hostapd-common=y

# ================= 额外插件 =================
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-p910nd=y
CONFIG_PACKAGE_luci-app-package-manager=y

# ================= 中文语言包 =================
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ddns-go-zh-cn=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-i18n-filebrowser-go-zh-cn=y
CONFIG_PACKAGE_luci-i18n-nfs-zh-cn=y

# Other Configuration
CONFIG_BUSYBOX_DEFAULT_FALLOCATE=y

CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-virtio-blk=y
CONFIG_PACKAGE_kmod-virtio-scsi=y


CONFIG_TARGET_ROOTFS_TARGZ=y
CONFIG_TARGET_ROOTFS_CPIOGZ=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

