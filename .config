# ================= 基础 UI 与主题 =================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-argon=y

# ================= 系统与监控工具 =================
CONFIG_PACKAGE_luci-app-ttyd=y          # 网页终端 (非常实用)
CONFIG_PACKAGE_luci-app-statistics=y    # 系统统计图表
CONFIG_PACKAGE_luci-app-nlbwmon=y       # 流量监控
CONFIG_PACKAGE_htop=y                   # 命令行进程管理
CONFIG_PACKAGE_iperf3=y                 # 网络测速工具

# ================= 网络与共享服务 =================
CONFIG_PACKAGE_luci-app-upnp=y          # UPnP (自动端口映射)
CONFIG_PACKAGE_luci-app-ddns=y          # 动态域名解析
CONFIG_PACKAGE_luci-app-wol=y           # 网络唤醒 (Wake-on-LAN)
CONFIG_PACKAGE_luci-app-samba4=y        # Samba 局域网文件共享
CONFIG_PACKAGE_luci-app-firewall=y      # 防火墙设置

# ================= 存储与下载工具 =================
CONFIG_PACKAGE_luci-app-dockerman=y     # Docker 管理界面
CONFIG_PACKAGE_dockerd=y                # Docker 守护进程
CONFIG_PACKAGE_luci-app-aria2=y         # Aria2 下载工具界面
CONFIG_PACKAGE_aria2=y                  # Aria2 核心
CONFIG_PACKAGE_luci-app-commands=y      # 自定义命令 (可在网页端执行快捷脚本)

# ================= USB 与文件系统支持 =================
CONFIG_PACKAGE_kmod-usb-storage=y       # USB 存储驱动
CONFIG_PACKAGE_kmod-usb-storage-uas=y   # UAS 高速 USB 驱动
CONFIG_PACKAGE_kmod-fs-ext4=y           # EXT4 文件系统支持
CONFIG_PACKAGE_kmod-fs-ntfs=y           # NTFS 文件系统支持
CONFIG_PACKAGE_ntfs-3g=y                # NTFS 读写支持
CONFIG_PACKAGE_block-mount=y            # 挂载点管理 (用于自动挂载 U盘/硬盘)

# ================= 基础网络组件 =================
CONFIG_IPV6=y                           # 开启 IPv6
CONFIG_PACKAGE_ipv6helper=y             # IPv6 辅助脚本
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y





CONFIG_PACKAGE_luci-app-aria2=y
# CONFIG_PACKAGE_luci-app-attendedsysupgrade is not set
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-p910nd=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-ttyd=y
# CONFIG_PACKAGE_luci-app-uhttpd is not set
CONFIG_PACKAGE_luci-app-wol=y

# end of 1. Applications

#
# 2. Themes
#
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
# CONFIG_PACKAGE_luci-theme-material is not set
CONFIG_PACKAGE_luci-theme-argon=y
# CONFIG_PACKAGE_luci-theme-openwrt is not set
# CONFIG_PACKAGE_luci-theme-openwrt-2020 is not set
# end of 2. Themes

#
# 3. Translate
#

CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ddns-go-zh-cn=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-i18n-filebrowser-go-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-i18n-nfs-zh-cn=y

# end of 3. Translate

#
# 4. Other Configuration
CONFIG_BUSYBOX_DEFAULT_FALLOCATE=y
# end of 4. Other Configuration






